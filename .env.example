# Bot token — Discord Developer Portal > Bot > Token
DISCORD_TOKEN=

# Application ID — Discord Developer Portal > General Information > Application ID
DISCORD_APP_ID=

# (Optional) Guild/Server ID for faster command registration during development.
# Right-click your server in Discord (Developer Mode on) > Copy Server ID.
# Leave empty to register global commands (takes ~1 hour to propagate).
DISCORD_GUILD_ID=
